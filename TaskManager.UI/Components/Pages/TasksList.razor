@page "/"
@page "/tasks"
@using TaskManager.Features.Tasks.Application.Models
@using TaskManager.Features.Tasks.Dtos
@inject TaskManager.UI.Services.TaskApiService TaskService

<h3>Tasks List</h3>

@if (tasks == null) {
    <p>Loading...</p>
}
else {
    @* <button @onclick="Test">
        TEST
    </button> *@
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Status</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in tasks.Items) {
                <tr>
                    <td>@task.Id</td>
                    <td>@task.Title</td>
                    <td>@task.Status</td>
                    <td>@task.CreatedAt</td>
                    <td>@task.UpdatedAt</td>
                    <td>
                        <button class="btn btn-success btn-sm" @onclick="() => CompleteTask(task.Id)">Complete</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteTask(task.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private PagedResult<ReadTaskItemDto> tasks;

    protected override async Task OnInitializedAsync()
    {
        tasks = await TaskService.GetTasksAsync();
    }

    private async Task CompleteTask(int id)
    {
        await TaskService.CompleteTaskAsync(id);
        tasks = await TaskService.GetTasksAsync();
    }
    // private async Task CompleteTask(int id)
    // {
    //     tasks.Items[0].Title = "CLICKED";

    //     await InvokeAsync(StateHasChanged);
    // }

    private async Task DeleteTask(int id)
    {
        await TaskService.DeleteTaskAsync(id);
        tasks = await TaskService.GetTasksAsync();
    }

    // private void Test()
    // {
    //     Console.WriteLine("TEST CLICK");
    // }
}